# ── Laby ADK agent service (Python) ─────────────────────────────────────
# Port the FastAPI app listens on (Cloud Run injects PORT=8080).
PORT=8080

# Logging level: INFO (default) or DEBUG for local development.
LOG_LEVEL=INFO

# Maximum seconds a single agent turn may run before timing out.
LABY_TURN_TIMEOUT=120

# DeepSeek LLM (OpenAI-compatible) via ADK's LiteLLM wrapper.
# Use a function-calling capable model: deepseek/deepseek-chat (V3).
# Do NOT use deepseek/deepseek-reasoner (R1) — it lacks tool calling.
LABY_MODEL=deepseek/deepseek-chat
DEEPSEEK_API_KEY=
# Optional: only set to point at a proxy / self-hosted OpenAI-compatible endpoint.
DEEPSEEK_API_BASE=

# Service-to-service auth. The Node backend calls THIS service with this key,
# and this service calls Node's /internal/laby-tools/* with the SAME key.
# Must equal INTERNAL_API_KEY in the Node backend (app.dentnode.com) env.
INTERNAL_API_KEY=

# Base URL of the Node backend API (note the /api mount prefix).
# Local docker-compose: http://node:3000/api
# Cloud Run:            https://app.dentnode.com/api
NODE_INTERNAL_BASE_URL=http://localhost:3000/api

# How many recent thread turns to load as short-term memory.
LABY_HISTORY_TURNS=12

# ── Cross-service parity (NOT consumed by this Python service) ────────────
# Kept for env consistency across both codebases. The agent does not call
# itself, and Redis (cache/rate-limit) lives in the Node backend.
LABY_AGENT_URL=http://localhost:8080
REDIS_URL=
