{
  "name": "ai.dentnode.com",
  "module": "src/index.ts",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun --watch --env-file=.env src/index.ts",
    "start": "bun --env-file=.env src/index.ts",
    "typecheck": "bunx tsc -p . --noEmit",
    "db:init": "bun --env-file=.env scripts/init_db.ts",
    "db:reset:ai": "bun --env-file=.env scripts/reset_ai_db.ts",
    "sync:prod-to-ai": "bun --env-file=.env scripts/populate_rag.ts",
    "sync:prod-to-ai:verify": "bun --env-file=.env scripts/confirm_population.ts",
    "sync:prod-to-ai:fresh": "bun run db:reset:ai && bun run sync:prod-to-ai && bun run sync:prod-to-ai:verify"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.2.3",
    "@elysiajs/stream": "^1.1.0",
    "@elysiajs/swagger": "^1.2.3",
    "@google/generative-ai": "^0.22.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "elysia": "^1.2.25",
    "mysql2": "^3.20.0",
    "openai": "^4.52.0",
    "pg": "^8.20.0",
    "prisma": "^7.6.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "typescript": "^5"
  }
}
